{
  "name": "cc-orga-tournoi",
  "version": "0.1.0",
  "description": "Application de gestion de concours de sport-boules (boule lyonnaise)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/api/bootstrap.ts",
    "start": "node dist/api/bootstrap.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run dev\" \"npm run dev:frontend\"",
    "db:generate": "drizzle-kit generate",
    "db:push":     "drizzle-kit push",
    "db:migrate":  "drizzle-kit migrate",
    "db:studio":   "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
