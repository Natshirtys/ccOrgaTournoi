{
  "version": 2,
  "builds": [
    {
      "src": "src/api/handler.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["src/**"] }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/api/handler.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
